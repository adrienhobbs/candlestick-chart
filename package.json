{
  "name": "@adrienhobbs/candlekit",
  "version": "0.1.0",
  "description": "React candlestick trading chart on TradingView Lightweight Charts, with a pluggable indicator system.",
  "license": "MIT",
  "author": "adrienhobbs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrienhobbs/candlestick-chart.git"
  },
  "keywords": [
    "trading",
    "candlestick",
    "lightweight-charts",
    "react",
    "chart",
    "indicators"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build:lib": "tsup && npm run build:css",
    "build:css": "tailwindcss -c tailwind.lib.config.js -i ./src/lib.css -o ./dist/styles.css --minify",
    "prepublishOnly": "npm run build:lib",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "peerDependencies": {
    "lightweight-charts": "^5.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "fast-technical-indicators": "^1.1.4",
    "lucide-react": "^0.344.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "lightweight-charts": "^5.0.0",
    "postcss": "^8.4.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
